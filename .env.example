# Porta do servidor HTTP (padrão: 3000)
PORT=3000

# Ambiente de execução: "development" ou "production"
NODE_ENV=development

# Nível de log: "debug", "info", "warn", "error" (padrão: info)
LOG_LEVEL=info

# Segredo para assinatura dos access tokens JWT (obrigatório)
JWT_SECRET=troque-por-um-segredo-forte-e-aleatorio

# Expiração do access token em segundos (padrão: 900 = 15 min)
JWT_ACCESS_TTL=900

# Expiração do refresh token em segundos (padrão: 604800 = 7 dias)
JWT_REFRESH_TTL=604800

# Administrador inicial criado no startup quando não há nenhum militar.
# Defina os três para habilitar o seed (caso contrário é ignorado).
ADMIN_RG=1
ADMIN_NOME=Administrador
ADMIN_SENHA=troque-esta-senha
