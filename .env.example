# Porta do servidor HTTP (padrão: 3000)
PORT=3000

# Ambiente de execução: "development" ou "production"
NODE_ENV=development

# Nível de log: "debug", "info", "warn", "error" (padrão: info)
LOG_LEVEL=info

# Segredo para assinatura dos access tokens JWT (obrigatório)
JWT_SECRET=troque-por-um-segredo-forte-e-aleatorio

# Expiração do access token em segundos (padrão: 900 = 15 min)
JWT_ACCESS_TTL=900
